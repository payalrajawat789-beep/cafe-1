# ============================================================
# BREW & BLISS CAFÉ — .gitignore
# ============================================================

# Environment Variables (NEVER push to GitHub!)
.env
.env.local
.env.development
.env.production
.env.*.local

# Node Modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
.next/
out/
build/

# Vercel
.vercel/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log

# Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
